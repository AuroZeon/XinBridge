{
  "name": "xinbridge",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "download-sounds": "node scripts/download-sounds.mjs",
    "download-sounds:force": "node scripts/download-sounds.mjs --force",
    "download-images": "node scripts/download-images.mjs",
    "download-images:force": "node scripts/download-images.mjs --force",
    "dev": "vite",
    "build": "npm run download-sounds && npm run download-images && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "cap:sync": "npm run build && npx cap sync",
    "cap:ios": "npm run cap:sync && npx cap open ios",
    "cap:android": "npm run cap:sync && npx cap open android",
    "cap:init": "npm run build && npx cap add ios && npx cap add android",
    "cap:icons": "capacitor-assets generate --pwa --iconBackgroundColor '#ffffff' --iconBackgroundColorDark '#0c4a3e' && mkdir -p public/icons && cp icons/*.webp public/icons/",
    "cap:icons:native": "capacitor-assets generate --iconBackgroundColor '#ffffff' --iconBackgroundColorDark '#0c4a3e'"
  },
  "dependencies": {
    "@capacitor/app-launcher": "^7.0.4",
    "@capacitor/core": "^7.0.0",
    "@capacitor/haptics": "^5.0.8",
    "@capacitor/motion": "^5.0.8",
    "canvas-confetti": "^1.9.4",
    "framer-motion": "^12.38.0",
    "howler": "^2.2.4",
    "lucide-react": "^0.577.0",
    "matter-js": "^0.20.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.0.0",
    "swiper": "^12.1.2"
  },
  "devDependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1"
  }
}
