# Local dev: create `.env` and/or `.env.local` in the project root (both are loaded by `npm run dev`;
# `.env.local` overrides `.env`). Restart the dev server after changing these.
# For Capacitor / mobile builds, set VITE_* before `npm run build` — values are baked into the app.

# Base URL of your deployed app (no trailing slash). Used when the app calls `/api/chat` on a remote host
# (e.g. no client-side AI keys). Example: https://xinbridge.vercel.app
VITE_API_URL=

# Optional: full URL to privacy policy. Defaults to privacy.html on the same origin.
# VITE_PRIVACY_POLICY_URL=https://example.com/privacy.html

# --- Mobile / client-side AI (Capacitor iOS & Android) — keys are embedded in the bundle; use a restricted key ---
# Direct OpenAI Chat Completions from the app via CapacitorHttp (avoids WebView CORS).
VITE_OPENAI_API_KEY=
# VITE_OPENAI_BASE_URL=https://api.openai.com/v1
VITE_OPENAI_MODEL=gpt-4o-mini
# VITE_OPENAI_MAX_TOKENS=2500
# Only if your model rejects max_completion_tokens: VITE_OPENAI_USE_LEGACY_MAX_TOKENS=true

# Optional: China-compatible API when app language is Chinese and this key is set (same /v1/chat/completions shape)
# VITE_CHINA_AI_API_KEY=
# VITE_CHINA_AI_BASE_URL=https://api.deepseek.com/v1
# VITE_CHINA_AI_MODEL=deepseek-chat

# --- Server-only (Vercel / `npm run dev` middleware) — not bundled into the app; no VITE_ prefix ---
# Used when VITE_OPENAI_* / VITE_CHINA_* are unset (web dev proxy or hosted API route).
OPENAI_API_KEY=
# OPENAI_MAX_TOKENS=2500
# OPENAI_USE_LEGACY_MAX_TOKENS=true
# OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

CHINA_AI_API_KEY=
CHINA_AI_BASE_URL=https://api.deepseek.com/v1
CHINA_AI_MODEL=deepseek-chat

# Hope Library (optional)
# SERPER_API_KEY=
